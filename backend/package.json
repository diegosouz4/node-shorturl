{
  "name": "node-shorturl-backend",
  "version": "1.0.0",
  "description": "API de encurtamento de URLs com Node.js, Express e Prisma, projetada com arquitetura modular, autenticação JWT, autorização baseada em papéis, logging estruturado e práticas modernas de desenvolvimento backend",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "npx prisma generate && ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "Diego Oliveira <https://github.com/diegosouz4>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/diegosouz4/node-shorturl"
  },
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.9",
    "dotenv": "^17.2.3",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.2.0",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
